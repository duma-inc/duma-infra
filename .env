COMPOSE_PROJECT_NAME=duma
ENVIRONMENT=development

# ==============================================
# POSTGRESQL
# ==============================================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=duma
POSTGRES_PASSWORD=163duma
POSTGRES_DB=duma_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ==============================================
# MONGODB
# ==============================================
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_INITDB_ROOT_USERNAME=duma
MONGO_INITDB_ROOT_PASSWORD=163duma
MONGO_INITDB_DATABASE=duma_db
MONGODB_URL=mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@${MONGO_HOST}:${MONGO_PORT}/${MONGO_INITDB_DATABASE}?authSource=admin

# ==============================================
# REDIS
# ==============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# ==============================================
# RABBITMQ
# ==============================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=duma
RABBITMQ_PASSWORD=163duma
RABBITMQ_VHOST=duma_vhost
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}/${RABBITMQ_VHOST}

# ==============================================
# SERVIÇOS DA APLICAÇÃO
# ==============================================

# API
API_PORT=8000
AVA_PORT=3001
ADM_PORT=3002

